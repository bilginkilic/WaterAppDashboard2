# Bu dosyayi kopyala: cp .env.example .env.local
# Netlify: Site settings → Environment variables → hepsini ayni ISIMLE ekle
#  - Scope: "All" / Production (ve Preview gerekiyorsa ayni)
#  - NEXT_PUBLIC_*: Build + runtime (Netlify "build" logunda da gerekli)
#  - Diger SERVER env: sadece API route'larinda (server)
#
# --- Firebase Web (ZORUNLU; Firebase Console → Project settings → Your apps) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
#
# --- Firebase Admin (ZORUNLU: /api/admin/users icin) — SEC BIR YOL:
#
# Yol A) Tek degisken: Service account JSON dosyasinin TAM icerigini
#      TEK satir string (veya Netlify cok satir "secret" alanina yapistir)
# FIREBASE_SERVICE_ACCOUNT=
#
# Yol A eski isim (desteklenir):
# FIREBASE_SERVICE_ACCOUNT_JSON=
#
# Yol B) Uc parca (Firebase → Project settings → Service accounts)
#        PRIVATE KEY: cok satirliysa Netlify "Contains multiple values"
#        veya tek satirda \n kacisli
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
#
# --- Yerel gelistirme (Netlify’da gerek yok) ---
# GOOGLE_APPLICATION_CREDENTIALS=./waterappdaily-firebase-adminsdk.json
