# Kopyala: cp .env.example .env
# Netlify: Site settings → Environment variables (Build için gerekli)

# Sadece yerel API kullanacaksanız (api klasöründe sunucu 3001’de iken):
# REACT_APP_API_URL=http://localhost:3001
#
# Boş bırakırsanız geliştirmede de Render URL kullanılır (config.ts).

# Netlify/production build: sonda / yok (isteğe bağlı; varsayılan zaten Render)
# REACT_APP_PRODUCTION_API_URL=https://waterappdashboard2.onrender.com

PORT=3002
