PORT=3001
JWT_SECRET=your-secret-key

# Firebase Web API Key (Firebase Console → Project settings → General → Web API Key)
# FIREBASE_WEB_API_KEY=your-firebase-web-api-key

# CORS: Netlify production URL (trailing slash yok)
# FRONTEND_DASHBOARD_ORIGIN=https://your-site.netlify.app

ADMIN_EMAIL=admin@waterapp.com
ADMIN_PASSWORD=admin123

# Firebase Admin (Render: Environment variables)
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# Tek satır JSON (tercih) VEYA api/firebase-service-account-new.json dosyası
# FIREBASE_SERVICE_ACCOUNT=